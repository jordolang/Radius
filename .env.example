# ── In The Mood (geosix) — environment template ──
# Copy to .env.local and fill in. Never commit real secrets.

# --- Database: Supabase Postgres (server-side, service role) ---
# Project URL + the SECRET service-role key (Supabase dashboard → Project
# Settings → API). The service-role key bypasses RLS and must NEVER be exposed
# to the client — it's used only by the server in lib/db/*. All tables are
# RLS-locked with no policies, so the publishable key alone grants zero access.
NEXT_PUBLIC_SUPABASE_URL="https://qpqftkkucsbsacqkbwlf.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_piAvdz45uiX3844aeTjMww_GErbZwNB"
SUPABASE_SERVICE_ROLE_KEY=""   # <-- paste the service_role secret here

# --- Auth: Clerk ---
# Create an application at https://dashboard.clerk.com, then paste both keys.
# Identity only — no real name is ever stored in our DB; the Clerk user id is
# the foreign key used across Supabase tables.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Realtime transport (replaces the dev polling relay in /api/signaling) ---
# Pick ONE provider for WebRTC signaling + chat. Examples:
# Ably
ABLY_API_KEY=""
# or Pusher
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# --- WebRTC ICE servers ---
# STUN is free (default in code). Add a TURN server for reliable connectivity
# behind strict NATs (e.g. Twilio, Metered, coturn).
TURN_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""

# --- Object storage for de-identified avatars (lib/avatarize output) ---
# e.g. Vercel Blob / S3-compatible
BLOB_READ_WRITE_TOKEN=""

# --- Age / identity verification provider (verify then minimize; never retain) ---
VERIFICATION_PROVIDER_KEY=""

# --- Map (home screen) ---
# Mapbox GL JS public token (pk.…). When set, the home map renders Mapbox vector
# tiles; when absent the app falls back to free Leaflet + Carto dark tiles, so it
# still runs token-free. This is a PUBLIC token (shipped to the browser) — scope
# it to your domains via URL restrictions in the Mapbox account, never use a
# secret (sk.…) token here.
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
